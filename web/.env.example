# --- Supabase (create a project at https://supabase.com, then Settings > API) ---
# Without these two, the app runs in DEMO MODE: bundled menu, orders in localStorage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key (Settings > API > "service_role"). SERVER-ONLY — never expose,
# never prefix with NEXT_PUBLIC. Lets the AI routes read the admin's OpenRouter
# API key from the protected `secret_` settings row. Optional: without it, the
# app falls back to OPENROUTER_API_KEY below.
SUPABASE_SERVICE_ROLE_KEY=

# --- Database setup (dev machine ONLY — never add this to Vercel) ---
# Postgres connection string for `npm run db:setup`, which applies
# supabase/schema.sql + seed.sql. Dashboard > Connect > "Session pooler" URI.
SUPABASE_DB_URL=

# --- OpenRouter (https://openrouter.ai/keys) — server-side only, never exposed ---
# Without this, AI panels show a friendly "assistant unavailable" state;
# ordering, billing and admin all keep working.
OPENROUTER_API_KEY=

# LLM used for all four AI features. Swappable without code changes.
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Google Gemini API Key ---
# Required for native Gemini fallback in AI Studio.
# Automatically injected by AI Studio at runtime.
GEMINI_API_KEY=

